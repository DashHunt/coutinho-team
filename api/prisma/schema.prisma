// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider            = "prisma-client"
  output              = "../generated/prisma"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== ENUMS ===================== //

enum LeadStatus {
  CRIADO
  INATIVO
  EM_ANDAMENTO
  CONCLUIDO
}

enum PlanStatus {
  ATIVO
  INATIVO
  EM_RENOVACAO
}

enum EventLevel {
  ESTADUAL
  NACIONAL
  INTERNACIONAL
}

enum EventAchievement {
  OURO
  PRATA
  BRONZE
  RECORDE
  PARTICIPACAO
}

enum FeedbackOptions {
  PROMOTOR
  PASSIVO
  DETRATOR
}

enum Role {
  ADMIN
  COACH
}

// ===================== TEAM =====================

model Team {
  id               Int       @id @default(autoincrement())
  name             String
  created_date     DateTime  @default(now())
  deleted_date     DateTime?
  modificated_date DateTime  @updatedAt
  users            Users[]
}

// ===================== USERS =====================

model Users {
  id               Int            @id @default(autoincrement())
  name             String
  email            String         @unique
  password         String
  role             Role           @default(COACH)
  team_id          Int
  team             Team           @relation(fields: [team_id], references: [id])
  refreshTokens    RefreshToken[]
  created_date     DateTime       @default(now())
  deleted_date     DateTime?
  modificated_date DateTime       @updatedAt
}

model RefreshToken {
  id           Int      @id @default(autoincrement())
  token_hash   String   @unique
  user_id      Int
  user         Users    @relation(fields: [user_id], references: [id])
  expires_at   DateTime
  revoked      Boolean  @default(false)
  created_date DateTime @default(now())
}

// ===================== LEADS =====================

model Lead {
  id               Int        @id @default(autoincrement())
  name             String
  email            String     @unique
  telephone_number String
  history          String?
  selected_plan    String?
  status           LeadStatus @default(CRIADO)
  created_date     DateTime   @default(now())
  deleted_date     DateTime?
  modificated_date DateTime   @updatedAt
  client           Client?
}

// ===================== PLANS =====================

model Plans {
  id                  Int                 @id @default(autoincrement())
  name                String
  mode                String
  duration            Int
  monthly_value       Int
  total_value         Int
  status              String
  created_date        DateTime            @default(now())
  deleted_date        DateTime?
  modificated_date    DateTime            @updatedAt
  clientPlanHistories ClientPlanHistory[]
}

// ===================== CLIENTS =====================

model Client {
  id                  Int                  @id @default(autoincrement())
  name                String
  email               String               @unique
  birth_date          DateTime
  gender              String
  telephone_number    String
  document            String?
  objectives          String?
  history             String?
  created_date        DateTime             @default(now())
  deleted_date        DateTime?
  modificated_date    DateTime             @updatedAt
  clientInfo          ClientInfo?
  clientAchiviments   ClientAchievements[]
  clientPlanHistories ClientPlanHistory[]
  clientFeedbacks     ClientFeedback[]
  lead_id             Int?                 @unique
  lead                Lead?                @relation(fields: [lead_id], references: [id])
}

model ClientPlanHistory {
  id               Int        @id @default(autoincrement())
  Client           Client     @relation(fields: [client_id], references: [id])
  client_id        Int
  Plan             Plans      @relation(fields: [plan_id], references: [id])
  plan_id          Int
  purchased_date   DateTime
  expiration_date  DateTime // calculado: purchased_date + Plan.duration
  status           PlanStatus @default(ATIVO)
  created_date     DateTime   @default(now())
  modificated_date DateTime   @updatedAt
}

model ClientInfo {
  id               Int       @id @default(autoincrement())
  Client           Client    @relation(fields: [client_id], references: [id])
  client_id        Int       @unique
  block            String
  block_week       String
  previous_block   String?   @default("No block registered")
  notes            String?
  sheet_link       String
  created_date     DateTime  @default(now())
  deleted_date     DateTime?
  modificated_date DateTime  @updatedAt
}

model ClientAchievements {
  id                Int              @id @default(autoincrement())
  Client            Client           @relation(fields: [client_id], references: [id])
  client_id         Int
  event             String
  event_level       EventLevel
  event_achievement EventAchievement
  event_date        DateTime
  created_date      DateTime         @default(now())
  deleted_date      DateTime?
  modificated_date  DateTime         @updatedAt
}

model ClientFeedback {
  id               Int             @id @default(autoincrement())
  Client           Client          @relation(fields: [client_id], references: [id])
  client_id        Int
  feedback         String
  feedback_nps     FeedbackOptions
  created_date     DateTime        @default(now())
  deleted_date     DateTime?
  modificated_date DateTime        @updatedAt
}
